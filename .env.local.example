MINIMAX_API_KEY=你的测试key
MINIMAX_BASE_URL=https://api.minimaxi.com
MINIMAX_TEXT_BASE_URL=https://api.minimax.io
MINIMAX_TEXT_MODEL=MiniMax-M2.7
MINIMAX_IMAGE_MODEL=image-01
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_VOICE_CLONE_MODEL=speech-2.8-hd
MINIMAX_VOICE_ID=

# 运行根目录。本地开发可以留空。
# Mac/Windows 打包运行时，建议把 VIDEO_FACTORY_DATA_ROOT 指向用户可写目录。
# macOS 示例：/Users/you/Library/Application Support/Video Factory
# Windows 示例：C:\Users\you\AppData\Roaming\Video Factory
VIDEO_FACTORY_APP_ROOT=
VIDEO_FACTORY_DATA_ROOT=
FFMPEG_PATH=

# 阿里云 DashScope / CosyVoice。推荐用于长文本旁白。
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
COSYVOICE_MODEL=cosyvoice-v2
COSYVOICE_CLONE_MODEL=voice-enrollment
COSYVOICE_TEST_VOICE_ID=longxiaochun_v2
COSYVOICE_VOICE_PREFIX=videofactory
COSYVOICE_CHUNK_CHAR_LIMIT=1800

# 生产样音存储：私有 OSS Bucket + 签名 GET URL，供 CosyVoice 复刻拉取。
ALIYUN_OSS_REGION=
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_PREFIX=video-factory/voice-samples
ALIYUN_OSS_SIGNED_URL_EXPIRES_SEC=3600

# 旧版兜底，仅当不用 OSS 时才需要。
PUBLIC_BASE_URL=

# 自定义声音克隆 / TTS 服务。
# VOICE_CLONE_ENDPOINT 接收 multipart: name, profileId, sample，返回 { voiceId }。
# VOICE_TTS_ENDPOINT 接收 JSON: { voiceId, voice_id, text, format }，返回 audio/*、{ audioBase64 } 或 { audioUrl }。
VOICE_PROVIDER_API_KEY=
VOICE_CLONE_ENDPOINT=
VOICE_TTS_ENDPOINT=
