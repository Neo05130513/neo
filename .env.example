MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com
MINIMAX_TEXT_BASE_URL=https://api.minimax.io
MINIMAX_TEXT_MODEL=MiniMax-M2.7
MINIMAX_IMAGE_MODEL=image-01
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_VOICE_CLONE_MODEL=speech-2.8-hd
MINIMAX_VOICE_ID=

# Runtime roots. Leave empty for local development.
# For packaged Mac/Windows apps, set VIDEO_FACTORY_DATA_ROOT to a user-writable directory.
# Examples:
# macOS: /Users/you/Library/Application Support/Video Factory
# Windows: C:\Users\you\AppData\Roaming\Video Factory
VIDEO_FACTORY_APP_ROOT=
VIDEO_FACTORY_DATA_ROOT=
FFMPEG_PATH=

# Aliyun DashScope / CosyVoice. Preferred provider for long-form narration.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
COSYVOICE_MODEL=cosyvoice-v2
COSYVOICE_CLONE_MODEL=voice-enrollment
COSYVOICE_TEST_VOICE_ID=longxiaochun_v2
COSYVOICE_VOICE_PREFIX=videofactory
COSYVOICE_CHUNK_CHAR_LIMIT=1800

# Production sample storage for CosyVoice voice clone. Use a private bucket and signed GET URLs.
ALIYUN_OSS_REGION=
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_PREFIX=video-factory/voice-samples
ALIYUN_OSS_SIGNED_URL_EXPIRES_SEC=3600

# Legacy fallback only. Prefer OSS above for production.
PUBLIC_BASE_URL=

# Custom voice clone / TTS provider.
# VOICE_CLONE_ENDPOINT should accept multipart fields: name, profileId, sample; return JSON { voiceId }.
# VOICE_TTS_ENDPOINT should accept JSON: { voiceId, voice_id, text, format }; return audio/*, { audioBase64 }, or { audioUrl }.
VOICE_PROVIDER_API_KEY=
VOICE_CLONE_ENDPOINT=
VOICE_TTS_ENDPOINT=
